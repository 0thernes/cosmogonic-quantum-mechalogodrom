#!/bin/sh
# Auto-repair UTF-8 mojibake in docs before EVERY commit (root-cause doc hygiene).
#
# The autonomous doc-writing loop corrupts README/docs into Windows-1252 mojibake
# each cycle. This hook runs the normalizer and re-stages the cleaned canonical
# docs so corrupted text can never land in a commit, keeping `tests/docs-truth-law`
# green without manual intervention. Enable once per clone with:
#     git config core.hooksPath .githooks
# Never blocks the commit (exit 0) — it only cleans.
bun scripts/normalize-docs.ts >/dev/null 2>&1 || exit 0
git add README.md CHANGELOG.md ROADMAP.md docs 2>/dev/null || true
exit 0
