#!/bin/sh
# Seamless local -> GitHub: auto-push every commit to its upstream the instant it lands, so the
# working branch on GitHub is never behind local and there is no manual "git push" round-trip.
#
# - Pushes the CURRENT branch to origin, setting upstream on first push.
# - NON-blocking: a failed push (offline / rejected) never harms the commit (it stays local; the
#   next commit's push, or a manual push, ships it).
# - Opt out per clone with:  git config hooks.autopush false
# Enabled via core.hooksPath .githooks (wired by the `prepare` npm/bun script on install).
[ "$(git config --bool hooks.autopush 2>/dev/null)" = "false" ] && exit 0
branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
[ -z "$branch" ] || [ "$branch" = "HEAD" ] && exit 0
git push -u origin "$branch" >/dev/null 2>&1 || echo "post-commit: auto-push deferred (push failed; commit is safe locally)"
exit 0
