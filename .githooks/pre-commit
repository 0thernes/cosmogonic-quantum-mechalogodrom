#!/bin/sh
# Auto-keep every commit's human-readable surfaces consistent with the single sources of truth,
# so duplicated info (version, test/coverage receipts) can NEVER drift across MD/HTML.
#
# 1. normalize-docs : reverse any UTF-8 -> Windows-1252 mojibake (docs-truth-law stays green).
# 2. sync-surfaces  : propagate package.json `version` + canonical-receipts to every surface.
# Both are idempotent and fail closed. A commit must never publish stale or partially generated
# truth surfaces merely because a generator or formatter failed.
#
# Enable once per clone (the `prepare` npm/bun script does this automatically on install):
#     git config core.hooksPath .githooks
set -eu

# The gate executes the worktree, so it can prove the staged commit only when no tracked or
# untracked non-ignored edits sit outside the index. This also prevents generator re-staging from
# accidentally capturing another task's work.
if ! git diff --quiet; then
  echo "pre-commit: tracked unstaged changes make the staged commit unverifiable." >&2
  echo "Stage or stash them, then retry the commit." >&2
  exit 1
fi
UNTRACKED=$(git ls-files --others --exclude-standard)
if [ -n "$UNTRACKED" ]; then
  echo "pre-commit: untracked non-ignored files make the staged commit unverifiable:" >&2
  printf '%s\n' "$UNTRACKED" >&2
  exit 1
fi

bun scripts/normalize-docs.ts >/dev/null
bun scripts/sync-surfaces.ts >/dev/null
# Re-stage only tracked surfaces changed by the generators. Untracked files are never swept into a
# commit. legacy/ is preserved verbatim.
CHANGED_SURFACES=$(git diff --name-only -- '*.md' '*.xml' '*.html' package.json ':(exclude)legacy/**')
if [ -n "$CHANGED_SURFACES" ]; then
  printf '%s\n' "$CHANGED_SURFACES" | tr '\n' '\0' | xargs -0 git add --
fi
# 3. prettier : auto-format every staged source/surface so NO writer (incl. an autonomous loop) can
#    ship format-dirty code. This is the root-cause fix for the recurring "origin/main fails
#    `prettier --check`" regression that turns CI red and blocks a fresh `bun run check`. Batched over
#    the STAGED set only (fast — not the whole repo), then re-staged. Formatter failures reject the
#    commit so the repository cannot drift behind a false-green hook.
STAGED_FMT=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
  | grep -Ei '\.(ts|tsx|js|jsx|mjs|cjs|css|json|ya?ml|md|html)$' \
  | grep -v '^legacy/' || :)
if [ -n "$STAGED_FMT" ]; then
  # Formatting happens in the worktree; a staged file with additional unstaged edits would be
  # collapsed into one commit by the re-stage below. Detect that ambiguity before touching it.
  printf '%s\n' "$STAGED_FMT" | while IFS= read -r file; do
    if ! git diff --quiet -- "$file"; then
      echo "pre-commit: $file has staged and unstaged edits; refusing to auto-format it." >&2
      exit 1
    fi
  done
  printf '%s\n' "$STAGED_FMT" | tr '\n' '\0' | xargs -0 bunx prettier --write >/dev/null
  printf '%s\n' "$STAGED_FMT" | tr '\n' '\0' | xargs -0 git add --
fi

# Binding repository law: nothing reaches the direct-main post-commit push without the same full
# gate used by CI. Any generated tracked drift left by the gate must be reviewed and staged on a
# second attempt; never auto-sweep it into this commit.
bun run check
if ! git diff --quiet; then
  echo "pre-commit: the full gate changed tracked files; review, stage, and retry." >&2
  git diff --name-only >&2
  exit 1
fi
